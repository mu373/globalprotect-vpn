#!/bin/bash
# Bring up the VPN. On first run, complete SSO in a browser.
# Cached auth tokens should make subsequent runs silent.
set -e

PORTAL=$(docker exec univ-vpn printenv GP_PORTAL 2>/dev/null || true)
if [ -z "$PORTAL" ]; then
    echo "error: GP_PORTAL is not set in the container. Set it in .env and re-run 'docker compose up -d'." >&2
    exit 1
fi
HOST="${HOSTNAME:-$(hostname)}"

# Stream gpclient output, detect the auth-server URL, print the SSH-forward command
docker exec -i -u vpnuser univ-vpn sudo -E gpclient connect --browser remote "$PORTAL" 2>&1 | \
while IFS= read -r line; do
    echo "$line"
    if [[ "$line" =~ http://([0-9.]+):([0-9]+)(/[^[:space:]]*) ]]; then
        ip="${BASH_REMATCH[1]}"
        port="${BASH_REMATCH[2]}"
        path="${BASH_REMATCH[3]}"
        cat >&2 <<EOF

────────────────────────────────────────────────────────────────────
  From a client, run in another terminal:

      ssh -L ${port}:${ip}:${port} ${HOST}

  Then open in a browser:

      http://localhost:${port}${path}

  Copy the globalprotectcallback:... string back into THIS terminal.
────────────────────────────────────────────────────────────────────

EOF
    fi
done
